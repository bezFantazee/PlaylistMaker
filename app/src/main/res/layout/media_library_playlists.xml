<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:theme="@style/Base.Theme.PlaylistMaker"
    android:id="@+id/playlistsFragment">
    
    <Button
        android:id="@+id/addNewPlaylistButton"
        style="@style/SmallButton"
        android:layout_width="133dp"
        android:layout_height="36dp"
        android:layout_marginTop="@dimen/big_margin"
        android:text="@string/new_playlist"/>

    <ImageView
        android:layout_width="@dimen/big_icon_size"
        android:layout_height="@dimen/big_icon_size"
        android:layout_marginTop="46dp"
        android:src="@drawable/ic_empty_media_library"
        android:backgroundTint="?attr/colorOnPrimary"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/small_margin"
        android:text="@string/user_did_not_create_playlists"
        android:textSize="@dimen/standart_text_size"
        android:textColor="?attr/colorOnPrimary"
        android:fontFamily="@font/ys_display_medium"
        android:textFontWeight="400"
        android:textAlignment="center"/>



</LinearLayout>