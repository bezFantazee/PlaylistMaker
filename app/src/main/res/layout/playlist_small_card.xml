<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="61dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <ImageView
        android:id="@+id/playlistImage"
        android:layout_width="45dp"
        android:layout_height="45dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:id="@+id/playlistName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/playlistImage"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tracksCount"
        android:layout_marginHorizontal="8dp"
        android:ellipsize="end"
        android:maxLines="1"

        android:textSize="16sp"
        android:fontFamily="@font/ys_display_regular"
        android:textFontWeight="400"
        android:textColor="?attr/colorOnPrimary"

        tools:text = "Названиииииииииииииииииииииииииииииииииииииииииииииииииииииииик"/>

    <TextView
        android:id="@+id/tracksCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/playlistName"
        app:layout_constraintStart_toStartOf="@id/playlistName"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/playlistName"
        android:ellipsize="end"
        android:maxLines="1"

        android:textSize="11sp"
        android:fontFamily="@font/ys_display_regular"
        android:textFontWeight="400"
        android:textColor="?attr/colorOnPrimary"

        tools:text = "10293908029813098109380911636`9   731781789-0990-8"/>
</androidx.constraintlayout.widget.ConstraintLayout>